---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/home/Hero.astro";
import { TerminalLive } from "../components/ui/TerminalLive";
import Skills from "../components/home/Skills.astro";
import Projects from "../components/home/Projects.astro";
---

<Layout>
  <main class="min-h-screen">
    <Hero />
    
    <section class="max-w-5xl mx-auto px-6 md:px-0 py-12 animate-fade-in-up" style="animation-delay: 400ms;">
      <h2 class="sr-only">Live Terminal Interface</h2>
      <TerminalLive client:visible />
    </section>

    <Skills />
    <Projects />
  </main>
</Layout>
