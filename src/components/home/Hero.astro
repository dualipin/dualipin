---
import { SITE } from "../../constants/site";
---
<section class="min-h-[85vh] flex flex-col justify-center relative px-6 md:px-0 pt-20">
  <div class="absolute inset-x-0 top-0 h-96 z-[-1] bg-linear-to-b from-base-200/50 to-transparent"></div>

  <div class="max-w-5xl mx-auto w-full">
    <div class="inline-flex items-center gap-2 px-3 py-1.5 mb-8 text-xs sm:text-sm font-mono bg-base-200 border border-base-300 rounded-md text-base-content/80 animate-fade-in-up">
      <span class="text-primary/80">➜</span>
      <span class="text-info">~</span>
      <span>./whoami.sh</span>
    </div>
    
    <h1 class="text-5xl sm:text-6xl md:text-7xl font-sans font-bold tracking-tighter text-balance leading-[1.1] mb-6 animate-fade-in-up" style="animation-delay: 100ms;">
      Architecting robust <br class="hidden md:block"/> <span class="text-base-content/60">systems &amp;</span> elegant interfaces.
    </h1>
    
    <p class="text-lg md:text-xl text-base-content/70 max-w-2xl font-mono leading-relaxed mb-10 animate-fade-in-up" style="animation-delay: 200ms;">
      Full Stack Engineer based in the void. Specializing in modern web infrastructure, scalable backends, and type-safe ecosystems.
    </p>

    <div class="flex flex-wrap gap-4 animate-fade-in-up" style="animation-delay: 300ms;">
      <a href="#projects" class="btn btn-neutral btn-lg border-base-content text-base-100 hover:bg-base-content/90 font-sans tracking-wide">
        Explore Architecture
      </a>
      <a href={SITE.github} target="_blank" rel="noopener noreferrer" class="btn btn-ghost border border-base-300 btn-lg font-mono">
        <span class="hidden sm:inline">cat</span> github.txt
      </a>
    </div>
  </div>
  
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce opacity-50">
    <div class="w-px h-16 bg-linear-to-b from-base-content to-transparent"></div>
  </div>
</section>
