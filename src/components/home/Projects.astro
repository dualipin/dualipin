---
import { Github, ExternalLink } from "@lucide/astro";

const projects = [
  {
    title: 'The "Python Pro"',
    description:
      "Enterprise dashboard combining a performant reactive frontend with a scalable Python backend handling millions of records.",
    link: "#",
    github: "#",
    architecture: {
      frontend:
        "Reactive interface built with React. Complex state management handled via modern Hooks and Context.",
      backend:
        "Robust API in FastAPI with Pydantic type validation. Efficient queries over PostgreSQL.",
      infra:
        "Deployed on Ubuntu Server (Azure) using Docker compose to ensure environment parity.",
    },
  },
  {
    title: 'The "Legacy Modernizer"',
    description:
      "Modernization of a legacy monolithic system proving deep understanding of web fundamentals and corporate environments.",
    link: "#",
    github: "#",
    architecture: {
      frontend:
        "Progressively decoupled UI components managed via Vanilla JS and lightweight libraries.",
      backend:
        "Refactored PHP/MySQL core. Implemented MVC layer over legacy spaghetti code.",
      infra:
        "Containerized local environment. Automated CI/CD pipeline for safe staging deployments.",
    },
  },
  {
    title: 'The "SysAdmin"',
    description:
      "Secure and performant infrastructure configuration for hosting multiple decoupled applications.",
    link: "#",
    github: "#",
    architecture: {
      frontend:
        "Static assets served optimally via CDN with aggressive caching policies.",
      backend:
        "Microservices architecture with internal network routing and rate limiting.",
      infra:
        "Azure VM configured with Nginx reverse proxy, SSL termination (Certbot), and fail2ban.",
    },
  },
];
---

<section id="projects" class="py-24 px-6 md:px-0 bg-base-200/20">
  <div class="max-w-5xl mx-auto">
    <div class="mb-16">
      <h2 class="text-3xl md:text-4xl font-sans font-bold tracking-tight mb-4">
        Featured Architecture
      </h2>
      <p class="text-base-content/70 font-mono text-sm max-w-xl">
        Showcasing deep understanding of the full stack, from reactive
        interfaces to server orchestration.
      </p>
    </div>

    <div class="space-y-24">
      {
        projects.map((project, index) => (
          <div class="relative">
            {/* Project Header */}
            <div class="mb-8 md:flex justify-between items-end border-b border-base-300 pb-6">
              <div>
                <div class="text-primary font-mono text-sm mb-2">
                  Project 0{index + 1}
                </div>
                <h3 class="text-2xl font-bold">{project.title}</h3>
                <p class="text-base-content/70 mt-3 max-w-2xl">
                  {project.description}
                </p>
              </div>
              <div class="flex gap-4 mt-6 md:mt-0">
                <a
                  href={project.github}
                  class="btn btn-circle btn-sm btn-ghost border border-base-300"
                >
                  <Github size={16} />
                </a>
                <a
                  href={project.link}
                  class="btn btn-outline btn-sm font-mono text-xs"
                >
                  Visit <ExternalLink size={14} class="ml-1" />
                </a>
              </div>
            </div>

            {/* Architecture Details - 3 Columns */}
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 font-mono text-sm">
              <div class="bg-base-100 p-5 rounded-lg border border-base-300">
                <div class="text-info font-bold mb-3 flex items-center gap-2">
                  <span class="w-2 h-2 rounded-sm bg-info" /> Frontend
                </div>
                <p class="text-base-content/70 leading-relaxed">
                  {project.architecture.frontend}
                </p>
              </div>

              <div class="bg-base-100 p-5 rounded-lg border border-base-300">
                <div class="text-success font-bold mb-3 flex items-center gap-2">
                  <span class="w-2 h-2 rounded-sm bg-success" /> Backend
                </div>
                <p class="text-base-content/70 leading-relaxed">
                  {project.architecture.backend}
                </p>
              </div>

              <div class="bg-base-100 p-5 rounded-lg border border-base-300">
                <div class="text-warning font-bold mb-3 flex items-center gap-2">
                  <span class="w-2 h-2 rounded-sm bg-warning" /> Infra
                </div>
                <p class="text-base-content/70 leading-relaxed">
                  {project.architecture.infra}
                </p>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
