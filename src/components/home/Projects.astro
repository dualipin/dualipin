---
import { Github, ExternalLink } from "@lucide/astro";

const projects = [
  {
    title: 'El "Python Pro"',
    description:
      "Dashboard empresarial combinando un frontend reactivo de alto rendimiento con un backend escalable en Python manejando millones de registros.",
    link: "#",
    github: "#",
    architecture: {
      frontend:
        "Interfaz reactiva construida con React. Gestión de estado complejo manejada mediante Hooks modernos y Context.",
      backend:
        "API robusta en FastAPI con validación de tipos Pydantic. Consultas eficientes sobre PostgreSQL.",
      infra:
        "Desplegado en Ubuntu Server (Azure) usando Docker compose para asegurar la paridad de entornos.",
    },
  },
  {
    title: 'El "Legacy Modernizador"',
    description:
      "Modernización de un sistema monolítico legacy demostrando un profundo entendimiento de los fundamentos web y entornos corporativos.",
    link: "#",
    github: "#",
    architecture: {
      frontend:
        "Componentes de UI desacoplados progresivamente gestionados mediante Vanilla JS y librerías ligeras.",
      backend:
        "Core de PHP/MySQL refactorizado. Capa MVC implementada sobre código legacy tipo spaghetti.",
      infra:
        "Entorno local containerizado. Pipeline de CI/CD automatizado para despliegues seguros a staging.",
    },
  },
  {
    title: 'El "SysAdmin"',
    description:
      "Configuración de infraestructura segura y de alto rendimiento para alojar múltiples aplicaciones desacopladas.",
    link: "#",
    github: "#",
    architecture: {
      frontend:
        "Archivos estáticos servidos óptimamente mediante CDN con políticas agresivas de caché.",
      backend:
        "Arquitectura de microservicios con enrutamiento de red interno y limitación de peticiones (rate limiting).",
      infra:
        "VM en Azure configurada con reverse proxy Nginx, terminación SSL (Certbot) y fail2ban.",
    },
  },
];
---

<section id="projects" class="py-24 px-6 md:px-0 bg-base-200/20">
  <div class="max-w-5xl mx-auto">
    <div class="mb-16">
      <h2 class="text-3xl md:text-4xl font-sans font-bold tracking-tight mb-4">
        Arquitectura Destacada
      </h2>
      <p class="text-base-content/70 font-mono text-sm max-w-xl">
        Demostrando un dominio profundo del full stack, desde interfaces reactivas
        hasta la orquestación de servidores.
      </p>
    </div>

    <div class="space-y-24">
      {
        projects.map((project, index) => (
          <div class="relative">
            {/* Project Header */}
            <div class="mb-8 md:flex justify-between items-end border-b border-base-300 pb-6">
              <div>
                <div class="text-primary font-mono text-sm mb-2">
                  Proyecto 0{index + 1}
                </div>
                <h3 class="text-2xl font-bold">{project.title}</h3>
                <p class="text-base-content/70 mt-3 max-w-2xl">
                  {project.description}
                </p>
              </div>
              <div class="flex gap-4 mt-6 md:mt-0">
                <a
                  href={project.github}
                  class="btn btn-circle btn-sm btn-ghost border border-base-300"
                >
                  <Github size={16} />
                </a>
                <a
                  href={project.link}
                  class="btn btn-outline btn-sm font-mono text-xs"
                >
                  Visitar <ExternalLink size={14} class="ml-1" />
                </a>
              </div>
            </div>

            {/* Architecture Details - 3 Columns */}
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 font-mono text-sm">
              <div class="bg-base-100 p-5 rounded-lg border border-base-300">
                <div class="text-info font-bold mb-3 flex items-center gap-2">
                  <span class="w-2 h-2 rounded-sm bg-info" /> Frontend
                </div>
                <p class="text-base-content/70 leading-relaxed">
                  {project.architecture.frontend}
                </p>
              </div>

              <div class="bg-base-100 p-5 rounded-lg border border-base-300">
                <div class="text-success font-bold mb-3 flex items-center gap-2">
                  <span class="w-2 h-2 rounded-sm bg-success" /> Backend
                </div>
                <p class="text-base-content/70 leading-relaxed">
                  {project.architecture.backend}
                </p>
              </div>

              <div class="bg-base-100 p-5 rounded-lg border border-base-300">
                <div class="text-warning font-bold mb-3 flex items-center gap-2">
                  <span class="w-2 h-2 rounded-sm bg-warning" /> Infra
                </div>
                <p class="text-base-content/70 leading-relaxed">
                  {project.architecture.infra}
                </p>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
